using System;
using System.Windows.Forms;
using App.Core.Models;
using App.Core.Utilities;
using App.Core.Services;

namespace App.WindowsApp.Forms
{
    public partial class MatchForm : Form
    {
        public MatchForm()
        {
            InitializeComponent();
            btnSave.Click += (s, e) => OnSave();
            LoadTeams();
        }

        private void LoadTeams()
        {
            try
            {
                var svc = new DbTeamService(AppConfig.ConnectionString);
                var teams = svc.GetAll();
                cmbTeamA.DisplayMember = "Name";
                cmbTeamA.ValueMember = "TeamId";
                cmbTeamA.DataSource = teams;

                cmbTeamB.DisplayMember = "Name";
                cmbTeamB.ValueMember = "TeamId";
                cmbTeamB.DataSource = new System.Collections.Generic.List<Team>(teams);
            }
            catch
            {
                // ignore loading errors; validation will catch missing teams
            }
        }

        private void OnSave()
        {
            // Basic validation: ensure teams selected
            var teamA = cmbTeamA.SelectedValue?.ToString();
            var teamB = cmbTeamB.SelectedValue?.ToString();
            if (string.IsNullOrWhiteSpace(teamA))
            {
                MessageBox.Show("Please select Team A.", "Validation", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }
            if (string.IsNullOrWhiteSpace(teamB))
            {
                MessageBox.Show("Please select Team B.", "Validation", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }
            if (teamA == teamB)
            {
                MessageBox.Show("Team A and Team B must be different.", "Validation", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            this.DialogResult = DialogResult.OK;
            this.Close();
        }

        public Match GetMatch()
        {
            DateTime dt = DateTime.Now.Date;
            try
            {
                var dtps = this.Controls.Find("dtpMatchDate", true);
                if (dtps != null && dtps.Length > 0 && dtps[0] is DateTimePicker dtp)
                    dt = dtp.Value.Date;
            }
            catch { }

            string resultText = "";
            try
            {
                var winners = this.Controls.Find("txtWinner", true);
                if (winners != null && winners.Length > 0 && winners[0] is TextBox tb)
                    resultText = tb.Text;
            }
            catch { }

            return new Match
            {
                MatchId = txtMatchId?.Text?.Trim(),
                Team1Id = cmbTeamA?.SelectedValue?.ToString() ?? cmbTeamA?.Text,
                Team2Id = cmbTeamB?.SelectedValue?.ToString() ?? cmbTeamB?.Text,
                MatchDate = dt,
                Status = MatchStatusEnum.Scheduled,
                Result = resultText
            };
        }

        public void SetMatch(Match m)
        {
            if (m == null) return;
            txtMatchId.Text = m.MatchId;
            try { cmbTeamA.SelectedValue = m.Team1Id; } catch { cmbTeamA.Text = m.Team1Id; }
            try { cmbTeamB.SelectedValue = m.Team2Id; } catch { cmbTeamB.Text = m.Team2Id; }
            try
            {
                var dtps = this.Controls.Find("dtpMatchDate", true);
                if (dtps != null && dtps.Length > 0 && dtps[0] is DateTimePicker dtp)
                    dtp.Value = m.MatchDate;
            }
            catch { }

            try
            {
                var winners = this.Controls.Find("txtWinner", true);
                if (winners != null && winners.Length > 0 && winners[0] is TextBox tb)
                    tb.Text = m.Result;
            }
            catch { }
        }

        public void DisableEditing()
        {
            try
            {
                var ids = this.Controls.Find("txtMatchId", true);
                if (ids != null && ids.Length > 0 && ids[0] is TextBox id)
                    id.ReadOnly = true;
            }
            catch { }

            try
            {
                var asCtr = this.Controls.Find("cmbTeamA", true);
                if (asCtr != null && asCtr.Length > 0 && asCtr[0] is ComboBox a)
                    a.Enabled = false;
            }
            catch { }

            try
            {
                var bsCtr = this.Controls.Find("cmbTeamB", true);
                if (bsCtr != null && bsCtr.Length > 0 && bsCtr[0] is ComboBox b)
                    b.Enabled = false;
            }
            catch { }

            try
            {
                var dtps = this.Controls.Find("dtpMatchDate", true);
                if (dtps != null && dtps.Length > 0 && dtps[0] is DateTimePicker dtp)
                    dtp.Enabled = false;
            }
            catch { }

            try
            {
                var grounds = this.Controls.Find("txtGround", true);
                if (grounds != null && grounds.Length > 0 && grounds[0] is TextBox g)
                    g.ReadOnly = true;
            }
            catch { }

            try
            {
                var winners = this.Controls.Find("txtWinner", true);
                if (winners != null && winners.Length > 0 && winners[0] is TextBox w)
                    w.ReadOnly = true;
            }
            catch { }

            try
            {
                var saves = this.Controls.Find("btnSave", true);
                if (saves != null && saves.Length > 0 && saves[0] is Button bs)
                    bs.Visible = false;
            }
            catch { }
        }
    }
}
