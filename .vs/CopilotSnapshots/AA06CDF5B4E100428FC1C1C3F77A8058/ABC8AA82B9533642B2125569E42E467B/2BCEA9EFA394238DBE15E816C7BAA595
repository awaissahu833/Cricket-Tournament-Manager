-- ============================================================
-- Cricket Tournament Manager — Database Setup Script
-- Run this in SQL Server Management Studio (SSMS) or
-- Visual Studio → SQL Server Object Explorer → New Query
-- ============================================================

-- 1. Create the database (skip if it already exists)
IF NOT EXISTS (SELECT name FROM sys.databases WHERE name = 'CricketTournamentDB')
    CREATE DATABASE CricketTournamentDB;
GO

USE CricketTournamentDB;
GO

-- 2. Teams
IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'Teams')
BEGIN
    CREATE TABLE Teams
    (
        TeamId  NVARCHAR(20)  NOT NULL PRIMARY KEY,
        Name    NVARCHAR(100) NOT NULL,
        Country NVARCHAR(50)  NOT NULL DEFAULT '',
        Coach   NVARCHAR(100) NOT NULL DEFAULT '',
        Captain NVARCHAR(100) NOT NULL DEFAULT ''
    );
    PRINT 'Table Teams created.';
END
GO

-- 3. Players
IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'Players')
BEGIN
    CREATE TABLE Players
    (
        PlayerId    NVARCHAR(20)  NOT NULL PRIMARY KEY,
        Name        NVARCHAR(100) NOT NULL,
        Nationality NVARCHAR(50)  NOT NULL DEFAULT '',
        Role        NVARCHAR(20)  NOT NULL DEFAULT 'Batsman',
        TeamId      NVARCHAR(20)  NULL
    );
    PRINT 'Table Players created.';
END
GO

-- 4. Matches
IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'Matches')
BEGIN
    CREATE TABLE Matches
    (
        MatchId   NVARCHAR(20)  NOT NULL PRIMARY KEY,
        Team1Id   NVARCHAR(20)  NOT NULL,
        Team2Id   NVARCHAR(20)  NOT NULL,
        MatchDate DATETIME      NOT NULL DEFAULT GETDATE(),
        Status    NVARCHAR(20)  NOT NULL DEFAULT 'Scheduled',
        Result    NVARCHAR(200) NOT NULL DEFAULT ''
    );
    PRINT 'Table Matches created.';
END
GO

