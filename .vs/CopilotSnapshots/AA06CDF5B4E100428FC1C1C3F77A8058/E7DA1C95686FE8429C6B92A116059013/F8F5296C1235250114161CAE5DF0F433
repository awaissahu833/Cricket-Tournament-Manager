using App.Core.Models;
using Microsoft.Data.SqlClient;
using System;
using System.Collections.Generic;
using System.Data;
using System.Linq;

namespace App.Core.Services
{
    public class DbPerformanceService
    {
        private readonly string _connectionString;

        public DbPerformanceService(string connString)
        {
            _connectionString = connString;
            try { EnsureTableExists(); } catch { }
        }

        private void EnsureTableExists()
        {
            using var conn = new SqlConnection(_connectionString);
            conn.Open();

            // check if table exists
            string check = "SELECT COUNT(*) FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME = 'Performances'";
            using (var cmd = new SqlCommand(check, conn))
            {
                var exists = Convert.ToInt32(cmd.ExecuteScalar()) > 0;
                if (exists) return;
            }

            string create = @"CREATE TABLE Performances (
                                PerformanceId NVARCHAR(50) PRIMARY KEY,
                                PlayerId NVARCHAR(100),
                                PlayerName NVARCHAR(200),
                                TeamId NVARCHAR(50),
                                TeamName NVARCHAR(200),
                                MatchId NVARCHAR(50),
                                MatchText NVARCHAR(300),
                                Runs INT DEFAULT 0,
                                Fours INT DEFAULT 0,
                                Sixes INT DEFAULT 0,
                                Wickets INT DEFAULT 0,
                                Overs NVARCHAR(50),
                                CreatedAt DATETIME DEFAULT GETUTCDATE()
                              );";

            using (var cmd = new SqlCommand(create, conn))
            {
                cmd.ExecuteNonQuery();
            }
        }

        public void Add(Performance p)
        {
            using var conn = new SqlConnection(_connectionString);
            conn.Open();

            string sql = @"INSERT INTO Performances (PerformanceId, PlayerId, PlayerName, TeamId, TeamName, MatchId, MatchText, Runs, Fours, Sixes, Wickets, Overs, CreatedAt)
                           VALUES (@PerformanceId, @PlayerId, @PlayerName, @TeamId, @TeamName, @MatchId, @MatchText, @Runs, @Fours, @Sixes, @Wickets, @Overs, @CreatedAt)";

            using var cmd = new SqlCommand(sql, conn);
            cmd.Parameters.AddWithValue("@PerformanceId", p.PerformanceId ?? Guid.NewGuid().ToString("N"));
            cmd.Parameters.AddWithValue("@PlayerId", p.PlayerId ?? (object)DBNull.Value);
            cmd.Parameters.AddWithValue("@PlayerName", p.PlayerName ?? (object)DBNull.Value);
            cmd.Parameters.AddWithValue("@TeamId", p.TeamId ?? (object)DBNull.Value);
            cmd.Parameters.AddWithValue("@TeamName", p.TeamName ?? (object)DBNull.Value);
            cmd.Parameters.AddWithValue("@MatchId", p.MatchId ?? (object)DBNull.Value);
            cmd.Parameters.AddWithValue("@MatchText", p.MatchText ?? (object)DBNull.Value);
            cmd.Parameters.AddWithValue("@Runs", p.Runs);
            cmd.Parameters.AddWithValue("@Fours", p.Fours);
            cmd.Parameters.AddWithValue("@Sixes", p.Sixes);
            cmd.Parameters.AddWithValue("@Wickets", p.Wickets);
            cmd.Parameters.AddWithValue("@Overs", p.Overs ?? (object)DBNull.Value);
            cmd.Parameters.AddWithValue("@CreatedAt", p.CreatedAt == default ? DateTime.UtcNow : p.CreatedAt);

            cmd.ExecuteNonQuery();
        }

        public List<Performance> GetTopBatters(int topN = 5)
        {
            var list = new List<Performance>();

            using var conn = new SqlConnection(_connectionString);
            conn.Open();

            string sql = $@"SELECT TOP(@top) PlayerId, PlayerName, SUM(Runs) AS Runs, SUM(Fours) AS Fours, SUM(Sixes) AS Sixes
                            FROM Performances
                            WHERE Runs IS NOT NULL
                            GROUP BY PlayerId, PlayerName
                            ORDER BY SUM(Runs) DESC";

            using var cmd = new SqlCommand(sql, conn);
            cmd.Parameters.AddWithValue("@top", topN);

            using var reader = cmd.ExecuteReader();
            while (reader.Read())
            {
                list.Add(new Performance
                {
                    PlayerId = reader["PlayerId"].ToString(),
                    PlayerName = reader["PlayerName"].ToString(),
                    Runs = reader["Runs"] != DBNull.Value ? Convert.ToInt32(reader["Runs"]) : 0,
                    Fours = reader["Fours"] != DBNull.Value ? Convert.ToInt32(reader["Fours"]) : 0,
                    Sixes = reader["Sixes"] != DBNull.Value ? Convert.ToInt32(reader["Sixes"]) : 0
                });
            }

            return list;
        }

        public List<Performance> GetTopBowlers(int topN = 5)
        {
            var list = new List<Performance>();

            using var conn = new SqlConnection(_connectionString);
            conn.Open();

            string sql = $@"SELECT TOP(@top) PlayerId, PlayerName, SUM(Wickets) AS Wickets
                            FROM Performances
                            WHERE Wickets IS NOT NULL
                            GROUP BY PlayerId, PlayerName
                            ORDER BY SUM(Wickets) DESC";

            using var cmd = new SqlCommand(sql, conn);
            cmd.Parameters.AddWithValue("@top", topN);

            using var reader = cmd.ExecuteReader();
            while (reader.Read())
            {
                list.Add(new Performance
                {
                    PlayerId = reader["PlayerId"].ToString(),
                    PlayerName = reader["PlayerName"].ToString(),
                    Wickets = reader["Wickets"] != DBNull.Value ? Convert.ToInt32(reader["Wickets"]) : 0
                });
            }

            return list;
        }
    }
}
