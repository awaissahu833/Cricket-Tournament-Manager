using System;
using System.Windows.Forms;

namespace App.WindowsApp.Views
{
    public partial class PerformanceView : UserControl
    {
        private readonly App.Core.Services.InMemoryPerformanceService _perfSvc;
        private readonly App.Core.Services.DbPerformanceService _dbPerfSvc;

        public PerformanceView()
        {
            InitializeComponent();
            _perfSvc = AppConfig.PerformanceService ??= new App.Core.Services.InMemoryPerformanceService();
            if (AppConfig.DbPerformanceService == null)
            {
                AppConfig.DbPerformanceService = new App.Core.Services.DbPerformanceService(AppConfig.ConnectionString);
            }
            _dbPerfSvc = AppConfig.DbPerformanceService;
            WireEvents();
        }

        private void WireEvents()
        {
            btnRefresh.Click += (s, e) => RefreshGrids();
            btnAdd.Click += (s, e) => OnAdd();
            btnEdit.Click += (s, e) => MessageBox.Show("Edit performance not implemented yet.");
            btnView.Click += (s, e) => MessageBox.Show("View performance not implemented yet.");
            btnDelete.Click += (s, e) => MessageBox.Show("Delete performance not implemented yet.");
        }

        private void RefreshGrids()
        {
            dgvBatters.Rows.Clear();
            dgvBowlers.Rows.Clear();

            try
            {
                var mem = _perfSvc?.GetAll() ?? new System.Collections.Generic.List<App.Core.Models.Performance>();
                var db = _dbPerfSvc != null ? _dbPerfSvc.GetAll() : new System.Collections.Generic.List<App.Core.Models.Performance>();

                // merge: prefer in-memory entries for immediacy, then append DB entries not already present
                var combined = new System.Collections.Generic.List<App.Core.Models.Performance>(mem);
                foreach (var d in db)
                {
                    if (!combined.Exists(x => x.PerformanceId == d.PerformanceId))
                        combined.Add(d);
                }

                // order by CreatedAt desc
                combined.Sort((a, b) => b.CreatedAt.CompareTo(a.CreatedAt));

                foreach (var p in combined)
                {
                    if (p.Runs > 0)
                        dgvBatters.Rows.Add(p.PlayerId, p.PlayerName, p.TeamName, p.Runs, p.Fours, p.Sixes);

                    if (p.Wickets > 0 || !string.IsNullOrWhiteSpace(p.Overs))
                        dgvBowlers.Rows.Add(p.PlayerId, p.PlayerName, p.TeamName, p.Wickets, p.Overs);
                }
            }
            catch { }
        }

        private void OnAdd()
        {
            try
            {
                using var form = new App.WindowsApp.Forms.PerformanceForm();
                if (form.ShowDialog() == DialogResult.OK)
                {
                    // read entered values and add to grids
                    var playerId = form.GetPlayerId();
                    var playerName = form.GetPlayerName();
                    var teamText = form.GetTeamText();

                    var runs = form.GetRuns();
                    var fours = form.GetFours();
                    var sixes = form.GetSixes();

                    var wickets = form.GetWickets();
                    var overs = form.GetOvers();

                    // add to in-memory service
                    var perf = new App.Core.Models.Performance
                    {
                        PerformanceId = Guid.NewGuid().ToString("N"),
                        PlayerId = playerId,
                        PlayerName = playerName,
                        TeamName = teamText,
                        Runs = runs,
                        Fours = fours,
                        Sixes = sixes,
                        Wickets = wickets,
                        Overs = overs
                    };

                    try
                    {
                        // persist to DB if available
                        _dbPerfSvc?.Add(perf);
                    }
                    catch { }

                    // also keep in-memory for immediate session queries
                    _perfSvc.Add(perf);

                    // refresh grids to reflect current top lists
                    RefreshGrids();
                }
                else
                {
                    // cancelled - nothing to do
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("Failed to open performance form: " + ex.Message, "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
    }
}
