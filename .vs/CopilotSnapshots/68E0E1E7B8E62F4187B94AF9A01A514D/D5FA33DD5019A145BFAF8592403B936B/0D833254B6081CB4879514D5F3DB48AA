-- Create database if not exists and create simple tables for CricketTournamentManager
IF DB_ID('CricketDB') IS NULL
BEGIN
	CREATE DATABASE [CricketDB];
END
GO

USE [CricketDB];
GO

-- Teams table
IF OBJECT_ID('dbo.Teams','U') IS NULL
BEGIN
	CREATE TABLE dbo.Teams (
		TeamId   NVARCHAR(10)  NOT NULL PRIMARY KEY,
		Name     NVARCHAR(200) NOT NULL,
		Country  NVARCHAR(100) NULL,
		Coach    NVARCHAR(100) NULL,
		Captain  NVARCHAR(100) NULL
	);
END
GO

-- Players table
IF OBJECT_ID('dbo.Players','U') IS NULL
BEGIN
	CREATE TABLE dbo.Players (
		PlayerId    NVARCHAR(10)  NOT NULL PRIMARY KEY,
		Name        NVARCHAR(200) NOT NULL,
		Nationality NVARCHAR(100) NULL,
		Role        NVARCHAR(50)  NOT NULL,
		TeamId      NVARCHAR(10)  NULL,
		CONSTRAINT FK_Players_Teams FOREIGN KEY (TeamId) REFERENCES dbo.Teams(TeamId) ON DELETE SET NULL
	);
END
GO

-- Matches table
IF OBJECT_ID('dbo.Matches','U') IS NULL
BEGIN
	CREATE TABLE dbo.Matches (
		MatchId   NVARCHAR(10)  NOT NULL PRIMARY KEY,
		Team1Id   NVARCHAR(10)  NOT NULL,
		Team2Id   NVARCHAR(10)  NOT NULL,
		MatchDate DATETIME2      NOT NULL,
		Status    NVARCHAR(50)  NOT NULL,
		Result    NVARCHAR(500) NULL,
		CONSTRAINT FK_Matches_Team1 FOREIGN KEY (Team1Id) REFERENCES dbo.Teams(TeamId),
		CONSTRAINT FK_Matches_Team2 FOREIGN KEY (Team2Id) REFERENCES dbo.Teams(TeamId)
	);
END
GO

